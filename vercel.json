{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/late-filings.js": { "memory": 256, "maxDuration": 30 },
    "api/momentum.js":     { "memory": 512, "maxDuration": 30 }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)",     "dest": "/public/$1" }
  ]
}
